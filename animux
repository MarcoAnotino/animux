# Main interactive loop: search -> select anime -> select episode -> playback.
# Handles back-navigation via return code 130 (Esc/cancel).
# Only re-shows the initial menu on explicit back from search prompt.
interactive_flow() {
    while :; do
        print_header

        case "$search" in
            history)
                anime_list=$(while read -r ep_no id title; do process_hist_entry & done <"$histfile")
                wait
                if [ -z "$anime_list" ] || [ -z "$histfile" ] || [ ! -s "$histfile" ]; then
                    status_msg "No unwatched series in history!"
                    if [ "$from_initial_menu" = "1" ]; then
                        search="scrape"
                        query=""
                        select_initial_mode
                        from_initial_menu=1
                        provider="$(resolve_provider)" || die "Unsupported provider: $provider."
                        check_provider_deps
                        continue
                    else
                        exit 1
                    fi
                fi

                selected_anime=""
                if [ -z "${index##*[!0-9]*}" ]; then
                    selected_anime=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Select anime [history]: ")
                    rc=$?
                    if [ "$rc" -eq 130 ] || [ -z "$selected_anime" ]; then
                        if [ "$from_initial_menu" = "1" ]; then
                            search="scrape"
                            query=""
                            select_initial_mode
                            from_initial_menu=1
                            provider="$(resolve_provider)" || die "Unsupported provider: $provider."
                            check_provider_deps
                            continue
                        else
                            exit 0
                        fi
                    fi
                else
                    selected_anime=$(printf "%s" "$anime_list" | sed -n "${index}p")
                    if [ -z "$selected_anime" ]; then
                        die "Invalid index: $index"
                    fi
                fi

                id=$(printf "%s" "$selected_anime" | cut -f1)
                title=$(printf "%s" "$selected_anime" | cut -f2 | sed 's/ - episode.*//')
                allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"

                status_msg "Fetching episodes..."
                ep_list=$(episodes_list "$id") || {
                    status_msg "Failed to fetch episodes"
                    continue
                }
                ep_no=$(printf "%s" "$anime_list" | grep "$id" | cut -f2 | sed -nE 's/.*- episode (.+)$/\1/p')

                mal_id=""
                playback_loop
                play_rc=$?
                if [ "$play_rc" -eq 200 ]; then
                    search="scrape"
                    query=""
                    ep_no=""
                    from_initial_menu=1
                    continue
                elif [ "$play_rc" -eq 130 ]; then
                    ep_no=""
                    continue
                else
                    cleanup
                    exit 0
                fi
                ;;

            search_history)
                if [ ! -s "$histfile" ]; then
                    status_msg "No history found!"
                    if [ "$from_initial_menu" = "1" ]; then
                        search="scrape"
                        query=""
                        select_initial_mode
                        from_initial_menu=1
                        provider="$(resolve_provider)" || die "Unsupported provider: $provider."
                        check_provider_deps
                    fi
                    continue
                fi
                anime_list=$(awk -F'\t' '
                    {
                        ids[NR] = $2
                        titles[NR] = $3
                    }
                    END {
                        for (i = NR; i > 0; i--) {
                            if (ids[i] != "" && !seen[ids[i]]++) {
                                print ids[i] "\t" titles[i]
                            }
                        }
                    }
                ' "$histfile")
                if [ -z "$anime_list" ]; then
                    status_msg "No history entries found!"
                    if [ "$from_initial_menu" = "1" ]; then
                        search="scrape"
                        query=""
                        select_initial_mode
                        from_initial_menu=1
                        provider="$(resolve_provider)" || die "Unsupported provider: $provider."
                        check_provider_deps
                    fi
                    continue
                fi

                selected_anime=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Select anime · History: ")
                rc=$?
                if [ "$rc" -eq 130 ] || [ -z "$selected_anime" ]; then
                    if [ "$from_initial_menu" = "1" ]; then
                        search="scrape"
                        query=""
                        select_initial_mode
                        from_initial_menu=1
                        provider="$(resolve_provider)" || die "Unsupported provider: $provider."
                        check_provider_deps
                    fi
                    continue
                fi

                id=$(printf "%s" "$selected_anime" | cut -f1)
                title=$(printf "%s" "$selected_anime" | cut -f2)
                allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
                case "$id" in
                    jkanime:* | animeflv:* | animeav1:* | *jkanime.net* | *animeflv.* | *animeav1.com*)
                        provider="python-extractor"
                        sub_lang="es"
                        ;;
                    *)
                        provider="allanime"
                        sub_lang="en"
                        ;;
                esac
                provider="$(resolve_provider)" || die "Unsupported provider: $provider"
                check_provider_deps

                while :; do
                    status_msg "Fetching episodes..."
                    ep_list=$(episodes_list "$id") || break

                    selected_ep=$(interactive_select_episode "$ep_list")
                    ep_rc=$?
                    if [ "$ep_rc" -eq 130 ]; then
                        ep_no=""
                        break
                    fi
                    ep_no="$selected_ep"

                    mal_id=""
                    playback_loop
                    play_rc=$?
                    if [ "$play_rc" -eq 200 ]; then
                        search="scrape"
                        query=""
                        ep_no=""
                        from_initial_menu=1
                        break
                    elif [ "$play_rc" -eq 130 ]; then
                        ep_no=""
                        continue
                    else
                        cleanup
                        exit 0
                    fi
                done
                continue
                ;;

            *)
                while :; do
                    search_query=$(interactive_search_prompt)
                    prompt_rc=$?
                    if [ "$prompt_rc" -eq 130 ] || [ -z "$search_query" ]; then
                        if [ "$from_initial_menu" = "1" ]; then
                            # User pressed Esc/Ctrl-D from search: go back to main menu
                            from_initial_menu=0
                            search="scrape"
                            query=""
                            select_initial_mode
                            from_initial_menu=1
                            provider="$(resolve_provider)" || die "Unsupported provider: $provider. Use auto, allanime or python-extractor."
                            check_provider_deps
                            break
                        else
                            exit 1
                        fi
                    fi

                    [ "$search" = "nextep" ] && time_until_next_ep "$search_query"

                    search_query_encoded=$(printf "%s" "$search_query" | sed "s| |+|g")
                    status_msg "Searching for $(language_display)..."
                    anime_list=$(search_anime "$search_query_encoded")
                    if [ -z "$anime_list" ]; then
                        status_msg "No results found!"
                        query=""
                        continue
                    fi

                    while :; do
                        selected_anime=$(interactive_select_anime "$anime_list")
                        sel_rc=$?
                        if [ "$sel_rc" -eq 130 ] || [ -z "$selected_anime" ]; then
                            query=""
                            break
                        fi

                        title=$(printf "%s" "$selected_anime" | cut -f2)
                        allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
                        id=$(printf "%s" "$selected_anime" | cut -f1)

                        while :; do
                            status_msg "Fetching episodes..."
                            ep_list=$(episodes_list "$id") || break

                            selected_ep=$(interactive_select_episode "$ep_list")
                            ep_rc=$?
                            if [ "$ep_rc" -eq 130 ]; then
                                ep_no=""
                                break
                            fi
                            ep_no="$selected_ep"

                            mal_id=""
                            playback_loop
                            play_rc=$?
                            if [ "$play_rc" -eq 200 ]; then
                                search="scrape"
                                query=""
                                ep_no=""
                                from_initial_menu=1
                                break 3
                            elif [ "$play_rc" -eq 130 ]; then
                                ep_no=""
                                continue
                            else
                                cleanup
                                exit 0
                            fi
                        done
                    done
                done
                ;;
        esac
    done
}

interactive_flow

