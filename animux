    if [ -w "${dir%*/mpv}" ]; then
        [ -d "${dir}" ] || mkdir "${dir}"
        printf "%s" "$3" | sed 's| --|\n|g; s|^--||g' >"$file"
    fi
    am start --user 0 -a android.intent.action.VIEW -d "$1" -n is.xyz.mpv/.MPVActivity -e "title" "$2" >/dev/null 2>&1
    unset dir file
}

play_episode() {
    [ "$log_episode" = 1 ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && command -v logger >/dev/null && logger -t animux "${allanime_title}${ep_no}"
    [ "$skip_intro" = 1 ] && skip_flag="$(ani-skip -q "$mal_id" -e "$ep_no")"
    if [ -z "$episode" ]; then
        status_msg "Resolving stream..."
        get_episode_url
    fi
    [ "$player_function" != "debug" ] && status_msg "Opening in $(player_label)..."
    # shellcheck disable=SC2086
    case "$player_function" in
        debug)
            printf "All links:\n%s\nSelected link:\n" "$links"
            printf "%s\n" "$episode"
            ;;
        mpv*)
            if [ "$no_detach" = 0 ]; then
                nohup $player_function $skip_flag --tls-verify=no --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $refr_flag >/dev/null 2>&1 &
            else
                $player_function $skip_flag $refr_flag --tls-verify=no --force-media-title="${allanime_title}Episode ${ep_no}" "$episode"
                mpv_exitcode=$?
                [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit "$mpv_exitcode"
            fi
            ;;
        android_mpv) "$player_function" "$episode" "${allanime_title}Episode ${ep_no}" "--tls-verify=no $refr_flag" 2>&1 & ;;
        android_vlc) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity -e "title" "${allanime_title}Episode ${ep_no}" >/dev/null 2>&1 & ;;
        *iina*)
            [ -n "$refr_flag" ] && refr_flag="--mpv-${refr_flag#--}"
            if pgrep -f "IINA" >/dev/null 2>&1; then
                # omit --keep-running when an IINA instance exists to prevent hanging
                nohup $player_function --no-stdin --mpv-tls-verify=no --mpv-force-media-title="${allanime_title}Episode ${ep_no}" $refr_flag "$episode" >/dev/null 2>&1 &
            else
                nohup $player_function --no-stdin --mpv-tls-verify=no --keep-running --mpv-force-media-title="${allanime_title}Episode ${ep_no}" $refr_flag "$episode" >/dev/null 2>&1 &
            fi
            ;;
        flatpak_mpv) flatpak run io.mpv.Mpv --tls-verify=no --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $refr_flag >/dev/null 2>&1 & ;;
        vlc*) nohup $player_function --http-referrer="${refr_flag#--referrer=}" --play-and-exit --meta-title="${allanime_title}Episode ${ep_no}" "$episode" >/dev/null 2>&1 & ;;
        *yncpla*) nohup $player_function "$episode" -- --tls-verify=no --force-media-title="${allanime_title}Episode ${ep_no}" $refr_flag >/dev/null 2>&1 & ;;
        download) "$player_function" "$episode" "${allanime_title}Episode ${ep_no}" ;;
        catt) nohup catt cast "$episode" >/dev/null 2>&1 & ;;
        iSH)
            printf "\e]8;;vlc://%s\a~~~~~~~~~~~~~~~~~~~~\n~ Tap to open VLC ~\n~~~~~~~~~~~~~~~~~~~~\e]8;;\a\n" "$episode"
            sleep 5
            ;;
        *) nohup $player_function "$episode" >/dev/null 2>&1 & ;;
    esac
    replay="$episode"
    unset episode
    update_history
    [ "$use_external_menu" = "1" ] && wait
    [ "$use_external_menu" = "2" ] && wait
}

play() {
    start=$(printf "%s" "$ep_no" | grep -Eo '^(-1|[0-9]+(\.[0-9]+)?)')
    end=$(printf "%s" "$ep_no" | grep -Eo '(-1|[0-9]+(\.[0-9]+)?)$')
    [ "$start" = "-1" ] && ep_no=$(printf "%s" "$ep_list" | tail -n1) && unset start
    [ -z "$end" ] || [ "$end" = "$start" ] && unset start end
    [ "$end" = "-1" ] && end=$(printf "%s" "$ep_list" | tail -n1)
    line_count=$(printf "%s\n" "$ep_no" | wc -l | tr -d "[:space:]")
    if [ "$line_count" != 1 ] || [ -n "$start" ]; then
        [ -z "$start" ] && start=$(printf "%s\n" "$ep_no" | head -n1)
        [ -z "$end" ] && end=$(printf "%s\n" "$ep_no" | tail -n1)
        range=$(printf "%s\n" "$ep_list" | sed -nE "/^${start}\$/,/^${end}\$/p")
        [ -z "$range" ] && die "Invalid range!"
        for i in $range; do
            tput clear
            ep_no=$i
            status_msg "Playing episode $ep_no..."
            [ "$i" = "$end" ] && unset range
            play_episode
        done
    else
        play_episode
    fi
    # moves up to stored position and deletes to end
    [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && tput rc && tput ed
}

playback_loop() {
    [ "$skip_intro" = 1 ] && [ -z "$mal_id" ] && mal_id="$(ani-skip -q "${skip_title:-${title}}")"
    play
    [ "$player_function" = "download" ] || [ "$player_function" = "debug" ] && return 0

    while :; do
        launcher_header="enter choose   esc back to episodes   $(clean_display_title "$title") · episode $ep_no"
        cmd=$(printf "next\nreplay\nprevious\nselect episode\nsearch\nchange quality\nquit\n" | nth "  playback  ")
        rc=$?
        unset launcher_header
        if [ "$rc" -eq 130 ] || [ -z "$cmd" ]; then
            return 130
        fi

        case "$cmd" in
            next)
                next_ep=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null
                if [ -z "$next_ep" ]; then
                    status_msg "Out of range"
                else
                    ep_no="$next_ep"
                    play
                fi
                ;;
            replay)
                episode="$replay"
                play
                ;;
            previous)
                prev_ep=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{g;1!p;};h") 2>/dev/null
                if [ -z "$prev_ep" ]; then
                    status_msg "Out of range"
                else
                    ep_no="$prev_ep"
                    play
                fi
                ;;
            *select*episode*)
                if [ "$use_external_menu" = "0" ]; then
                    launcher_header="$(ui_episode_header "$title")"
                    launcher_height="${ANI_CLI_EPISODE_MENU_HEIGHT:-95%}"
                    ui_prepare_episode_preview "$title" || true
                else
                    launcher_header="Enter: select · Esc: back · $(clean_display_title "$title")"
                fi
                new_ep=$(printf "%s" "$ep_list" | nth "  choose episode  " "$multi_selection_flag")
                new_ep_rc=$?
                ui_cleanup_episode_preview
                unset launcher_height
                unset launcher_header
                if [ "$new_ep_rc" -ne 130 ] && [ -n "$new_ep" ]; then
                    ep_no="$new_ep"
                    play
                fi
                ;;
            search)
                return 200
                ;;
            *change*quality*)
                launcher_header="enter apply   esc back   current $quality"
                new_quality="$(printf "%s" "$links" | launcher "" "  choose quality  " | cut -d\> -f1)"
                unset launcher_header
                if [ -n "$new_quality" ]; then
                    select_quality "$new_quality"
                    play
                fi
                ;;
            *)
                return 0
                ;;
        esac
    done
}

