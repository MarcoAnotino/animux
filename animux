    [ "${ANIMUX_NO_HEADER:-${ANI_CLI_NO_HEADER:-0}}" = "1" ] && return 0
    [ "${ANIMUX_HEADER:-${ANI_CLI_HEADER:-1}}" = "0" ] && return 0
