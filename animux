#!/bin/sh

version_number="4.14.1"

# ANIMUX_* is the public configuration namespace. Legacy ANI_CLI_* variables
# remain supported so existing upstream configurations continue to work.
for animux_env_name in \
    ART_SIZE ASCII_ART ASCII_ART_DIR AUTO_SELECT_SINGLE BRANCH BUILTIN_ART_HEIGHT CACHE COLOR DEFAULT_SOURCE \
    DOWNLOAD_DIR EPISODE_ART EPISODE_ART_SIZE EPISODE_MENU_HEIGHT \
    EPISODE_PREVIEW_WINDOW EXIT_AFTER_PLAY EXTERNAL_MENU \
    EXTERNAL_MENU_NORMAL_WINDOW FZF_BORDER FZF_COLORS FZF_HEIGHT HEADER \
    HIST_DIR JKANIME_CONNECT_TIMEOUT JKANIME_MAX_TIME LANG LOG \
    MAIN_MENU_HEIGHT MODE MULTI_SELECTION NO_DETACH NO_HEADER PLAYER PROVIDER \
    QUALITY RANDOM_ASCII_ART REMOTE_ART SEARCH_MENU_HEIGHT SKIP_INTRO SKIP_TITLE UI_MESSAGES
do
    eval "animux_env_is_set=\${ANIMUX_${animux_env_name}+yes}"
    if [ "$animux_env_is_set" = "yes" ]; then
        eval "ANI_CLI_${animux_env_name}=\${ANIMUX_${animux_env_name}}"
    fi
done
unset animux_env_name animux_env_is_set

# Metadata cache. Final playback URLs and resolved embeds are intentionally not
# routed through these helpers because they can expire or require fresh headers.
normalize_cache_value() {
    printf '%s' "$*" |
        tr '+\t\n' '   ' |
        tr '[:upper:]' '[:lower:]' |
        sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

cache_digest() {
    if command -v sha256sum >/dev/null 2>&1; then
        printf '%s' "$1" | sha256sum | awk '{ print $1 }'
    elif command -v shasum >/dev/null 2>&1; then
        printf '%s' "$1" | shasum -a 256 | awk '{ print $1 }'
    else
        # cksum is specified by POSIX and produces filename-safe output.
        printf '%s' "$1" | cksum | awk '{ print $1 "-" $2 }'
    fi
}

cache_provider_for_id() {
    case "$1" in
        jkanime:*) printf '%s' jkanime ;;
        animeflv:*) printf '%s' animeflv ;;
        animeav1:*) printf '%s' animeav1 ;;
        *) printf '%s' "$provider" ;;
    esac
}

cache_read() {
    [ "$animux_cache_enabled" = "1" ] || return 1
    [ -r "$1" ] || return 1

    IFS= read -r _animux_cache_saved <"$1" || return 1
    case "$_animux_cache_saved" in
        '' | *[!0-9]*) return 1 ;;
    esac
    _animux_cache_now="$(date +%s 2>/dev/null)" || return 1
    case "$_animux_cache_now" in
        '' | *[!0-9]*) return 1 ;;
    esac
    _animux_cache_age=$((_animux_cache_now - _animux_cache_saved))
    [ "$_animux_cache_age" -ge 0 ] && [ "$_animux_cache_age" -lt "$2" ] || return 1
    sed '1d' "$1"
}

cache_write() {
    [ "$animux_cache_enabled" = "1" ] || return 0
    [ -n "$2" ] || return 0
    _animux_cache_parent=${1%/*}
    mkdir -p "$_animux_cache_parent" 2>/dev/null || return 0
    _animux_cache_now="$(date +%s 2>/dev/null)" || return 0
    _animux_cache_tmp="$1.$$"
    if (umask 077; { printf '%s\n' "$_animux_cache_now"; printf '%s\n' "$2"; } >"$_animux_cache_tmp"); then
        mv -f "$_animux_cache_tmp" "$1" 2>/dev/null || rm -f "$_animux_cache_tmp"
    else
        rm -f "$_animux_cache_tmp"
    fi
}

cache_get_or_run() {
    _animux_cache_kind="$1"
    _animux_cache_ttl="$2"
    _animux_cache_key="$3"
    shift 3

    if [ "$animux_cache_enabled" != "1" ]; then
        "$@"
        return
    fi

    _animux_cache_hash="$(cache_digest "$_animux_cache_key")" || {
        "$@"
        return
    }
    _animux_cache_file="$animux_cache_root/$_animux_cache_kind/$_animux_cache_hash"
    if cache_read "$_animux_cache_file" "$_animux_cache_ttl"; then
        return 0
    fi

    _animux_cache_output="$("$@")"
    _animux_cache_status=$?
    if [ "$_animux_cache_status" -eq 0 ] && [ -n "$_animux_cache_output" ]; then
        cache_write "$_animux_cache_file" "$_animux_cache_output"
    fi
    printf '%s\n' "$_animux_cache_output"
    return "$_animux_cache_status"
}

find_runtime_file() {
    animux_file_name="$1"
    shift
    for animux_search_dir do
        [ -n "$animux_search_dir" ] || continue
        if [ -r "$animux_search_dir/$animux_file_name" ]; then
            printf '%s\n' "$animux_search_dir/$animux_file_name"
            return 0
        fi
    done
    return 1
}

find_runtime_dir() {
    for animux_search_dir do
        [ -n "$animux_search_dir" ] || continue
        if [ -d "$animux_search_dir" ]; then
            printf '%s\n' "$animux_search_dir"
            return 0
        fi
    done
    return 1
}

find_art_file() {
    animux_art_name="$1"
    animux_explicit_path="$2"
    animux_legacy_path="$3"
    if [ -n "$animux_explicit_path" ] && [ -r "$animux_explicit_path" ]; then
        printf '%s\n' "$animux_explicit_path"
        return 0
    fi
    if [ -n "$animux_legacy_path" ] && [ -r "$animux_legacy_path" ]; then
        printf '%s\n' "$animux_legacy_path"
        return 0
    fi
    find_runtime_file "$animux_art_name" \
        "${ANIMUX_SHARE_DIR:-}" \
        "$script_dir" \
        "${PREFIX:+$PREFIX/share/animux}" \
        "$animux_runtime_prefix/share/animux" \
        "/usr/local/share/animux" \
        "/opt/homebrew/share/animux" \
        "$HOME/.local/share/animux"
}

select_random_art_file() {
    [ -d "$1" ] || return 1
    animux_random_time="$(date +%s 2>/dev/null || printf 1)"
    animux_random_seed="$(printf '%s\n' "$$:$animux_random_time" | cksum | awk '{ print $1 }')"
    find "$1" -type f -name '*.txt' 2>/dev/null | LC_ALL=C sort |
        awk -v seed="$animux_random_seed" '
        BEGIN { srand(seed) }
        { if (rand() * NR < 1) selected = $0 }
        END {
            if (selected != "") print selected
        }
    '
}

# UI

ui_init() {
    if [ -t 2 ] && [ "${TERM:-dumb}" != "dumb" ] && [ -z "${NO_COLOR:-}" ] && [ "${ANI_CLI_COLOR:-1}" != "0" ]; then
        ui_reset="$(printf '\033[0m')"
        ui_bold="$(printf '\033[1m')"
        ui_dim="$(printf '\033[2m')"
        ui_ink="$(printf '\033[38;5;255m')"
        ui_muted="$(printf '\033[38;5;245m')"
        ui_accent="$(printf '\033[38;5;213m')"
        ui_accent_alt="$(printf '\033[38;5;81m')"
        ui_success="$(printf '\033[38;5;121m')"
        ui_warning="$(printf '\033[38;5;221m')"
        ui_error="$(printf '\033[38;5;203m')"
        ui_fzf_colors="${ANI_CLI_FZF_COLORS:-fg:253,bg:233,hl:213,fg+:233,bg+:213,hl+:233,prompt:81,query:253,pointer:81,marker:121,header:245,border:240,info:245}"
    else
        ui_reset=""
        ui_bold=""
        ui_dim=""
        ui_ink=""
        ui_muted=""
        ui_accent=""
        ui_accent_alt=""
        ui_success=""
        ui_warning=""
        ui_error=""
        ui_fzf_colors=""
    fi
}

ui_scale_braille_art() {
    perl -CSDA - "$1" "$2" "${3:-}" "${4:-}" "${5:-}" <<'PERL'
use strict;
use warnings;

my ($file, $target_rows, $max_cols, $canvas_cols, $canvas_rows) = @ARGV;
open my $fh, '<:encoding(UTF-8)', $file or exit 1;
my @lines = <$fh>;
close $fh;
chomp @lines;
shift @lines if @lines && $lines[0] =~ /^\s*\w+\s*=\s*"""\s*$/;
pop @lines if @lines && $lines[-1] =~ /^\s*"""\s*$/;
shift @lines while @lines && $lines[0] =~ /^\s*$/;
pop @lines while @lines && $lines[-1] =~ /^\s*$/;
exit 1 unless @lines;

my $source_rows = scalar @lines;
my $source_cols = 0;
for my $line (@lines) {
    my $length = length $line;
    $source_cols = $length if $length > $source_cols;
}

# Custom files may contain conventional ASCII rather than braille. Character
# art cannot be resampled without changing its shapes, so retain it verbatim
# and apply safe bounds instead.
my $has_braille = grep { /[\x{2800}-\x{28FF}]/ } @lines;
if (!$has_braille) {
    if (defined $max_cols && $max_cols =~ /^\d+$/ && $max_cols > 0) {
        splice @lines, $target_rows if @lines > $target_rows;
        @lines = map { length($_) > $max_cols ? substr($_, 0, $max_cols) : $_ } @lines;
    }
    my $output_cols = 0;
    for my $line (@lines) {
        $output_cols = length($line) if length($line) > $output_cols;
    }
    my $left_padding = 0;
    if (defined $canvas_cols && $canvas_cols =~ /^\d+$/ && $canvas_cols > $output_cols) {
        $left_padding = int(($canvas_cols - $output_cols) / 2);
    }
    my $top_padding = 0;
    if (defined $canvas_rows && $canvas_rows =~ /^\d+$/ && $canvas_rows > @lines) {
        $top_padding = int(($canvas_rows - scalar @lines) / 2);
    }
    print "\n" x $top_padding;
    print((' ' x $left_padding) . "$_\n") for @lines;
    exit 0;
}

my @dot_map = (
    [0, 0, 0], [0, 1, 1], [0, 2, 2], [1, 0, 3],
    [1, 1, 4], [1, 2, 5], [0, 3, 6], [1, 3, 7],
);
my @source;
for my $char_y (0 .. $#lines) {
    my @chars = split //, $lines[$char_y];
    for my $char_x (0 .. $#chars) {
        my $mask = ord($chars[$char_x]) - 0x2800;
        next if $mask < 0 || $mask > 255;
        for my $dot (@dot_map) {
            my ($x, $y, $bit) = @$dot;
            $source[$char_y * 4 + $y][$char_x * 2 + $x] = 1
                if $mask & (1 << $bit);
        }
    }
}

my $source_width = $source_cols * 2;
my $source_height = $source_rows * 4;
my $target_cols;

# With both limits, fit the art inside the preview while preserving its
# proportions. Never enlarge menu art that already fits: upscaling braille
# makes its dots sparse and inconsistent with the rest of the collection.
if (defined $max_cols && $max_cols =~ /^\d+$/ && $max_cols > 0) {
    my $row_scale = $target_rows / $source_rows;
    my $col_scale = $max_cols / $source_cols;
    my $scale = 1;
    $scale = $row_scale if $row_scale < $scale;
    $scale = $col_scale if $col_scale < $scale;
    $target_rows = int($source_rows * $scale + 0.5);
    $target_cols = int($source_cols * $scale + 0.5);
} else {
    $target_cols = int(($source_cols * $target_rows / $source_rows) + 0.5);
}
$target_rows = 1 if $target_rows < 1;
$target_cols = 1 if $target_cols < 1;
my $left_padding = 0;
if (defined $canvas_cols && $canvas_cols =~ /^\d+$/ && $canvas_cols > $target_cols) {
    $left_padding = int(($canvas_cols - $target_cols) / 2);
}
my $top_padding = 0;
if (defined $canvas_rows && $canvas_rows =~ /^\d+$/ && $canvas_rows > $target_rows) {
    $top_padding = int(($canvas_rows - $target_rows) / 2);
}
my $target_width = $target_cols * 2;
my $target_height = $target_rows * 4;
my @scaled;

for my $target_y (0 .. $target_height - 1) {
    my $source_y0 = int($target_y * $source_height / $target_height);
    my $source_y1 = int(($target_y + 1) * $source_height / $target_height) - 1;
    $source_y1 = $source_y0 if $source_y1 < $source_y0;
    for my $target_x (0 .. $target_width - 1) {
        my $source_x0 = int($target_x * $source_width / $target_width);
        my $source_x1 = int(($target_x + 1) * $source_width / $target_width) - 1;
        $source_x1 = $source_x0 if $source_x1 < $source_x0;
        my ($active, $area) = (0, 0);
        for my $source_y ($source_y0 .. $source_y1) {
            for my $source_x ($source_x0 .. $source_x1) {
                $active += $source[$source_y][$source_x] // 0;
                $area++;
            }
        }
        $scaled[$target_y][$target_x] = 1 if $active * 8 >= $area;
    }
}

print "\n" x $top_padding;
for my $char_y (0 .. $target_rows - 1) {
    my $output = '';
    for my $char_x (0 .. $target_cols - 1) {
        my $mask = 0;
        for my $dot (@dot_map) {
            my ($x, $y, $bit) = @$dot;
            $mask |= 1 << $bit if $scaled[$char_y * 4 + $y][$char_x * 2 + $x];
        }
        $output .= chr(0x2800 + $mask);
    }
    $output =~ s/\x{2800}+$//;
    print((' ' x $left_padding) . "$output\n");
}
PERL
}

ui_center_text_block() {
    perl -CSDA - "$1" "$2" "$3" <<'PERL'
use strict;
use warnings;

my ($text, $canvas_cols, $top_padding) = @ARGV;
my @lines = split /\n/, $text;
my $content_cols = 0;

for my $line (@lines) {
    my $visible = $line;
    $visible =~ s/\e\[[0-?]*[ -\/]*[@-~]//g;
    my $length = length $visible;
    $content_cols = $length if $length > $content_cols;
}

$canvas_cols = 0 unless defined $canvas_cols && $canvas_cols =~ /^\d+$/;
$top_padding = 0 unless defined $top_padding && $top_padding =~ /^\d+$/;
my $left_padding = $canvas_cols > $content_cols
    ? int(($canvas_cols - $content_cols) / 2)
    : 0;

print "\n" x $top_padding;
print((' ' x $left_padding) . "$_\n") for @lines;
PERL
}

ui_builtin_art() {
    ui_art_file="$animux_builtin_art"
    logo_only="${1:-}"

    if [ -r "$ui_art_file" ] && command -v perl >/dev/null 2>&1; then
        printf "%s" "$ui_accent"
        # Print non-braille lines (box-drawing / text logo) directly
        perl -CSDA -e '
            use strict; use warnings;
            my $file = $ARGV[0];
            open my $fh, "<:encoding(UTF-8)", $file or exit 1;
            my @lines = <$fh>; close $fh;
            chomp @lines;
            shift @lines if @lines && $lines[0]  =~ /^\s*\w+\s*=\s*"""\s*$/;
            pop  @lines if @lines && $lines[-1] =~ /^\s*"""\s*$/;
            for my $line (@lines) {
                my $is_braille = ($line =~ /^[\x{2800}-\x{28FF}\x{00}-\x{7E}]*$/);
                next if $is_braille;
                next if $line =~ /^\s*$/;  # skip blank separator lines
                print "$line\n";
            }
        ' "$ui_art_file"
        printf "%s" "$ui_reset"

        # Full mode: also scale and render the braille pixel art
        if [ -z "$logo_only" ]; then
            terminal_lines="${LINES:-$(tput lines 2>/dev/null || printf "24")}"
            case "$terminal_lines" in
                "" | *[!0-9]*) terminal_lines=24 ;;
            esac
            if [ -n "${ANI_CLI_BUILTIN_ART_HEIGHT:-}" ]; then
                art_height="$ANI_CLI_BUILTIN_ART_HEIGHT"
            elif [ "$terminal_lines" -lt 32 ]; then
                art_height=10
            elif [ "$terminal_lines" -lt 48 ]; then
                art_height=14
            elif [ "$terminal_lines" -lt 70 ]; then
                art_height=17
            else
                art_height=21
            fi
            printf "%s" "$ui_accent"
            ui_scale_braille_art "$ui_art_file" "$art_height"
            printf "%s" "$ui_reset"
        fi
    fi
    printf "%s%sANIMUX%s  %snight signal · stream anime from your terminal%s\n" \
        "$ui_bold" "$ui_ink" "$ui_reset" "$ui_muted" "$ui_reset"
}

ui_main_header() {
    # Logo-only: just the box art, no braille — keeps fzf header compact so menu options are visible
    ui_builtin_art logo_only
    printf "%s%s%s\n" "$ui_accent_alt" '  enter select   esc back   ctrl-c quit' "$ui_reset" " "
}

ui_remote_art() {
    [ "${ANI_CLI_REMOTE_ART:-auto}" != "0" ] || return 1
    command -v chafa >/dev/null 2>&1 || return 1
    command -v curl >/dev/null 2>&1 || return 1

    art_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/animux"
    art_file="$art_cache_dir/terminal-art.png"
    art_fresh=""
    [ -s "$art_file" ] && art_fresh="$(find "$art_file" -mtime -1 -print 2>/dev/null)"

    if [ -z "$art_fresh" ]; then
        mkdir -p "$art_cache_dir" 2>/dev/null || return 1
        art_json="$(curl --fail --silent --show-error --location \
            --connect-timeout 2 --max-time 4 \
            -A "animux/$version_number (https://github.com/MarcoAnotino/animux)" \
            "https://nekos.best/api/v2/neko" 2>/dev/null)"
        art_url="$(printf "%s" "$art_json" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)"
        if [ -n "$art_url" ]; then
            art_tmp="$art_file.tmp.$$"
            if curl --fail --silent --location --connect-timeout 2 --max-time 6 \
                -A "animux/$version_number (https://github.com/MarcoAnotino/animux)" \
                "$art_url" -o "$art_tmp" 2>/dev/null; then
                mv "$art_tmp" "$art_file"
            else
                rm -f "$art_tmp"
            fi
        fi
    fi

    [ -s "$art_file" ] || return 1
    chafa --format=symbols --symbols=block --size="${ANI_CLI_ART_SIZE:-24x10}" --animate=off "$art_file" 2>/dev/null ||
        chafa --size="${ANI_CLI_ART_SIZE:-24x10}" "$art_file" 2>/dev/null || return 1
    printf "%sart via nekos.best%s\n" "$ui_dim" "$ui_reset"
}

ui_compact_header() {
    printf "%s%sANIMUX%s  %snight signal%s\n" "$ui_bold" "$ui_accent" "$ui_reset" "$ui_muted" "$ui_reset"
    printf "%s%s%s\n" "$ui_ink" "$1" "$ui_reset"
    printf "%s%s%s\n" "$ui_muted" "$2" "$ui_reset"
}

ui_search_header() {
    ui_compact_header "search anime" "type a title   enter search   esc back   $(language_display)"
}

terminal_query_launcher() {
    launcher_header="$(ui_search_header)"
    FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-}${ui_fzf_colors:+ --color=$ui_fzf_colors}" \
        fzf --ansi \
        --reverse \
        --height="${ANI_CLI_SEARCH_MENU_HEIGHT:-45%}" \
        --border="${ANI_CLI_FZF_BORDER:-rounded}" \
        --pointer=">" \
        --marker="+" \
        --print-query \
        --phony \
        --info=hidden \
        --prompt="  search · $(language_display)  " \
        --header="$launcher_header" </dev/null | sed -n '1p'
    unset launcher_header
}

ui_fetch_cover_file() {
    [ "${ANI_CLI_EPISODE_ART:-1}" != "0" ] || return 1
    command -v curl >/dev/null 2>&1 || return 1
    command -v perl >/dev/null 2>&1 || return 1

    cover_query="$(clean_display_title "$1" | sed 's/[[:space:]]*:[[:space:]].*$//')"
    cover_key="$(printf "%s" "$cover_query" | cksum | awk '{print $1}')"
    cover_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/animux/covers"
    cover_file="$cover_cache_dir/$cover_key.jpg"

    if [ ! -s "$cover_file" ]; then
        mkdir -p "$cover_cache_dir" 2>/dev/null || return 1
        cover_json="$(curl --fail --silent --location \
            --connect-timeout 2 --max-time 5 \
            -A "animux/$version_number (https://github.com/MarcoAnotino/animux)" \
            --get --data-urlencode "q=$cover_query" --data "limit=1" --data "sfw=true" \
            "https://api.jikan.moe/v4/anime" 2>/dev/null)"

        cover_url="$(printf "%s" "$cover_json" | perl -MJSON::PP -0777 -ne '
            $response = decode_json($_);
            print $response->{data}[0]{images}{jpg}{large_image_url} // q{};
        ' 2>/dev/null)"

        [ -n "$cover_url" ] || return 1

        cover_tmp="$cover_file.tmp.$$"
        if curl --fail --silent --location --connect-timeout 2 --max-time 6 \
            -A "animux/$version_number (https://github.com/MarcoAnotino/animux)" \
            "$cover_url" -o "$cover_tmp" 2>/dev/null; then
            mv "$cover_tmp" "$cover_file"
        else
            rm -f "$cover_tmp"
            return 1
        fi
    fi

    printf "%s\n" "$cover_file"
}

ui_render_cover() {
    cover_file="$1"
    if [ -n "${ANI_CLI_EPISODE_ART_SIZE:-}" ]; then
        cover_size="$ANI_CLI_EPISODE_ART_SIZE"
        cover_width="${cover_size%%x*}"
        cover_rows="${cover_size#*x}"
        case "$cover_width:$cover_rows" in
            *[!0-9:]* | 0:* | *:0) cover_width=30; cover_rows=14 ;;
        esac
    else
        # Query terminal size using stty first, then tput, then environment/defaults
        stty_size="$(stty size 2>/dev/null)"
        if [ -n "$stty_size" ]; then
            term_lines="${stty_size%% *}"
            term_cols="${stty_size#* }"
        else
            term_lines="${LINES:-$(tput lines 2>/dev/null || printf "24")}"
            term_cols="${COLUMNS:-$(tput cols 2>/dev/null || printf "80")}"
        fi
        case "$term_lines" in ""|*[!0-9]*) term_lines=24 ;; esac
        case "$term_cols" in ""|*[!0-9]*) term_cols=80 ;; esac

        # Assume 50% split for preview window, subtract borders and padding
        usable_width=$(( (term_cols / 2) - 4 ))
        usable_height=$(( term_lines - 3 ))

        [ "$usable_width" -gt 10 ] || usable_width=10
        [ "$usable_height" -gt 5 ] || usable_height=5

        # aspect ratio 2:3 -> height_pixels = width * 1.5 -> rows = width * 0.75
        # width <= usable_height / 0.75 = usable_height * 4 / 3
        max_width_from_height=$(( usable_height * 4 / 3 ))
        if [ "$usable_width" -gt "$max_width_from_height" ]; then
            cover_width="$max_width_from_height"
        else
            cover_width="$usable_width"
        fi

        cover_rows=$(( cover_width * 3 / 4 ))

        [ "$cover_width" -gt 10 ] || cover_width=10
        [ "$cover_rows" -gt 5 ] || cover_rows=5
    fi
    cover_pixels=$((cover_rows * 2))

    ffmpeg -v error -i "$cover_file" \
        -vf "scale=${cover_width}:${cover_pixels}:flags=lanczos:force_original_aspect_ratio=decrease,pad=${cover_width}:${cover_pixels}:(ow-iw)/2:(oh-ih)/2:color=0x15131a" \
        -frames:v 1 -f rawvideo -pix_fmt rgb24 - 2>/dev/null |
        perl -e '
            use strict;
            use warnings;
            my ($width, $height) = @ARGV;
            binmode STDIN;
            binmode STDOUT, ":encoding(UTF-8)";

            my $truecolor = ($ENV{COLORTERM} // "") =~ /^(truecolor|24bit)$/i;
            if (($ENV{TERM_PROGRAM} // "") eq "Apple_Terminal") {
                $truecolor = 0;
            }

            # Read all raw pixels
            my $needed = $width * $height * 3;
            my $raw = "";
            while (length($raw) < $needed) {
                my $rd = read STDIN, my $chunk, $needed - length($raw);
                last unless $rd;
                $raw .= $chunk;
            }
            exit 1 if length($raw) < $needed;

            if ($truecolor) {
                # 24-bit direct output — full quality, no dithering needed
                for (my $y = 0; $y < $height; $y += 2) {
                    for my $x (0 .. $width - 1) {
                        my $top = ($y * $width + $x) * 3;
                        my $bot = (($y + 1) * $width + $x) * 3;
                        my ($tr,$tg,$tb) = unpack "C3", substr($raw, $top, 3);
                        my ($br,$bg,$bb) = unpack "C3", substr($raw, $bot, 3);
                        printf "\e[38;2;%d;%d;%dm\e[48;2;%d;%d;%dm\x{2580}",
                            $tr,$tg,$tb, $br,$bg,$bb;
                    }
                    print "\e[0m\n";
                }
            } else {
                # ── 256-color with Floyd-Steinberg dithering ──

                # Pre-compute the 256-color palette (indices 16-255)
                my @pal;  # $pal[$i] = [$r, $g, $b]
                # 16-231: 6×6×6 colour cube
                for my $ri (0..5) {
                    for my $gi (0..5) {
                        for my $bi (0..5) {
                            $pal[16 + 36*$ri + 6*$gi + $bi] = [
                                $ri ? 55 + 40*$ri : 0,
                                $gi ? 55 + 40*$gi : 0,
                                $bi ? 55 + 40*$bi : 0,
                            ];
                        }
                    }
                }
                # 232-255: greyscale ramp
                for my $i (0..23) {
                    my $v = 8 + 10*$i;
                    $pal[232 + $i] = [$v, $v, $v];
                }

                # Find nearest palette colour (perceptually weighted)
                sub nearest {
                    my ($r, $g, $b) = @_;
                    my ($best, $best_d) = (16, 1e18);
                    for my $i (16..255) {
                        my $dr = $r - $pal[$i][0];
                        my $dg = $g - $pal[$i][1];
                        my $db = $b - $pal[$i][2];
                        # Weighted: green 4×, red 2×, blue 3× (approx. human perception)
                        my $d = 2*$dr*$dr + 4*$dg*$dg + 3*$db*$db;
                        if ($d < $best_d) { $best_d = $d; $best = $i; }
                    }
                    return $best;
                }

                # Load pixel grid as floats for error diffusion
                my @px;
                for my $y (0 .. $height - 1) {
                    for my $x (0 .. $width - 1) {
                        my $off = ($y * $width + $x) * 3;
                        my @c = unpack "C3", substr($raw, $off, 3);
                        $px[$y][$x] = \@c;
                    }
                }

                # Floyd-Steinberg dithering pass
                my @qi;  # quantised palette index per pixel
                for my $y (0 .. $height - 1) {
                    for my $x (0 .. $width - 1) {
                        my @c = @{$px[$y][$x]};
                        # Clamp
                        for (@c) { $_ = 0 if $_ < 0; $_ = 255 if $_ > 255; }
                        my $idx = nearest(int($c[0]+.5), int($c[1]+.5), int($c[2]+.5));
                        $qi[$y][$x] = $idx;
                        # Compute error
                        my @e = ($c[0]-$pal[$idx][0], $c[1]-$pal[$idx][1], $c[2]-$pal[$idx][2]);
                        # Diffuse error to neighbours
                        if ($x + 1 < $width) {
                            $px[$y][$x+1][$_]   += $e[$_] * 7/16 for 0..2;
                        }
                        if ($y + 1 < $height) {
                            if ($x > 0) {
                                $px[$y+1][$x-1][$_] += $e[$_] * 3/16 for 0..2;
                            }
                            $px[$y+1][$x][$_]   += $e[$_] * 5/16 for 0..2;
                            if ($x + 1 < $width) {
                                $px[$y+1][$x+1][$_] += $e[$_] * 1/16 for 0..2;
                            }
                        }
                    }
                }

                # Render half-block pairs
                for (my $y = 0; $y < $height; $y += 2) {
                    for my $x (0 .. $width - 1) {
                        printf "\e[38;5;%dm\e[48;5;%dm\x{2580}",
                            $qi[$y][$x], $qi[$y+1][$x];
                    }
                    print "\e[0m\n";
                }
            }
        ' "$cover_width" "$cover_pixels"
}

ui_anime_cover_art() {
    [ "${ANI_CLI_EPISODE_ART:-1}" != "0" ] || return 1
    [ -n "$ui_fzf_colors" ] || return 1
    command -v ffmpeg >/dev/null 2>&1 || return 1
    command -v perl >/dev/null 2>&1 || return 1

    cover_file="$(ui_fetch_cover_file "$1")" || return 1
    ui_render_cover "$cover_file" || return 1
    printf "%scover via Jikan / MyAnimeList%s\n" "$ui_dim" "$ui_reset"
}

ui_episode_header() {
    ui_compact_header "$(clean_display_title "$1")" "enter select   esc back   $(language_display)"
}

ui_prepare_episode_preview() {
    launcher_preview_file=""
    launcher_preview_image=""

    cover_file="$(ui_fetch_cover_file "$1")" || return 1
    launcher_preview_image="$cover_file"

    preview_file="$(mktemp "${TMPDIR:-/tmp}/animux-cover.XXXXXX")" || return 1
    if ui_render_cover "$cover_file" >"$preview_file"; then
        launcher_preview_file="$preview_file"
    else
        rm -f "$preview_file"
        launcher_preview_file=""
    fi

    export ANI_CLI_LAUNCHER_PREVIEW_FILE="$launcher_preview_file"
    export ANI_CLI_LAUNCHER_PREVIEW_IMAGE="$launcher_preview_image"

    [ -n "$launcher_preview_image" ] || [ -n "$launcher_preview_file" ]
}

ui_cleanup_episode_preview() {
    [ -n "${launcher_preview_file:-}" ] && rm -f "$launcher_preview_file"
    unset launcher_preview_file
    unset launcher_preview_image
    unset ANI_CLI_LAUNCHER_PREVIEW_FILE
    unset ANI_CLI_LAUNCHER_PREVIEW_IMAGE

    # Clear persistent terminal graphics protocol images (Kitty/Ghostty/WezTerm/Foot) immediately
    [ -t 2 ] && [ -w /dev/tty ] && printf '\033_Ga=d;\033\\' >/dev/tty 2>/dev/null

    # Send a delayed clear in the background to ensure terminal has fully swapped screen buffers
    (sleep 0.05 && [ -t 2 ] && [ -w /dev/tty ] && printf '\033_Ga=d;\033\\' >/dev/tty 2>/dev/null) &
}

ui_rule() {
    printf "%s%s%s\n" "$ui_muted" '────────────────────────────────────────────────────────' "$ui_reset"
}

ui_init

external_menu() {
    if [ "$use_external_menu" = "1" ]; then
        if [ -n "$launcher_header" ]; then
            rofi "$1" -sort -dmenu -i -width 1500 -p "$2" -mesg "$launcher_header" "$3"
        else
            rofi "$1" -sort -dmenu -i -width 1500 -p "$2" "$3"
        fi
    elif [ "$use_external_menu" = "2" ]; then
        dmenu -l 20 -p "$2"
    fi
}

fzf_command() {
    have_preview=0

    if [ -n "${launcher_preview_image:-}" ] && [ -r "$launcher_preview_image" ]; then
        have_preview=1
    elif [ -n "${launcher_preview_file:-}" ] && [ -r "$launcher_preview_file" ]; then
        have_preview=1
    fi

    if [ "$have_preview" = "1" ]; then
        preview_cmd='
if [ -n "${ANI_CLI_LAUNCHER_PREVIEW_IMAGE:-}" ] && [ -r "${ANI_CLI_LAUNCHER_PREVIEW_IMAGE:-}" ]; then
    # 1. Try Chafa (supports WezTerm, Ghostty, Kitty, iTerm, Sixel, etc.)
    if command -v chafa >/dev/null 2>&1; then
        chafa_fmt="auto"
        # Detect Kitty protocol terminals: Ghostty, Kitty, WezTerm, Foot, Rio
        if [ -n "${KITTY_WINDOW_ID:-}" ] || [ "${TERM_PROGRAM:-}" = "ghostty" ] || [ "${TERM:-}" = "xterm-ghostty" ] || [ -n "${WEZTERM_PANE:-}" ] || [ "${TERM:-}" = "foot" ]; then
            chafa_fmt="kitty"
        # Detect iTerm protocol terminals: iTerm2, WezTerm
        elif [ "${TERM_PROGRAM:-}" = "iTerm.app" ]; then
            chafa_fmt="iterm"
        fi
        chafa --format="$chafa_fmt" --size="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}" --scale=max "${ANI_CLI_LAUNCHER_PREVIEW_IMAGE}" 2>/dev/null && exit 0
    fi

    # 2. Try WezTerm imgcat native command
    if [ -n "${WEZTERM_PANE:-}" ] && command -v wezterm >/dev/null 2>&1; then
        wezterm imgcat "${ANI_CLI_LAUNCHER_PREVIEW_IMAGE}" 2>/dev/null && exit 0
    fi

    # 3. Try Kitty native icat kitten
    if [ -n "${KITTY_WINDOW_ID:-}" ] && command -v kitty >/dev/null 2>&1; then
        kitty +kitten icat --clear --silent --stdin=no >/dev/tty 2>/dev/null || true
        kitty +kitten icat \
            --silent \
            --stdin=no \
            --transfer-mode=file \
            --place="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}@0x0" \
            "${ANI_CLI_LAUNCHER_PREVIEW_IMAGE}" 2>/dev/null && exit 0
    fi

    # 4. Try iTerm2 imgcat native script
    if [ "${TERM_PROGRAM:-}" = "iTerm.app" ] && command -v imgcat >/dev/null 2>&1; then
        imgcat "${ANI_CLI_LAUNCHER_PREVIEW_IMAGE}" 2>/dev/null && exit 0
    fi
fi

# 5. Fallback to Floyd-Steinberg dithered ANSI block text
if [ -n "${ANI_CLI_LAUNCHER_PREVIEW_FILE:-}" ] && [ -r "${ANI_CLI_LAUNCHER_PREVIEW_FILE:-}" ]; then
    cat "${ANI_CLI_LAUNCHER_PREVIEW_FILE}"
fi
'

        FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-}${ui_fzf_colors:+ --color=$ui_fzf_colors}" \
            fzf "$@" \
            --preview="$preview_cmd" \
            --preview-window="${ANI_CLI_EPISODE_PREVIEW_WINDOW:-right,50%,border-left}"
    else
        FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-}${ui_fzf_colors:+ --color=$ui_fzf_colors}" fzf "$@"
    fi
}

launcher() {
    [ "$use_external_menu" = "0" ] && [ -z "$1" ] && set -- "+m" "$2"
    if [ "$use_external_menu" = "0" ]; then
        if [ -n "$launcher_header" ]; then
            fzf_command "$1" \
                --ansi \
                --reverse \
                --cycle \
                --height="${launcher_height:-${ANI_CLI_FZF_HEIGHT:-80%}}" \
                --border="${ANI_CLI_FZF_BORDER:-rounded}" \
                --pointer=">" \
                --marker="+" \
                --info=inline \
                --prompt "$2" \
                --header="$launcher_header"
        else
            fzf_command "$1" \
                --ansi \
                --reverse \
                --cycle \
                --height="${launcher_height:-${ANI_CLI_FZF_HEIGHT:-80%}}" \
                --border="${ANI_CLI_FZF_BORDER:-rounded}" \
                --pointer=">" \
                --marker="+" \
                --info=inline \
                --prompt "$2"
        fi
    elif [ "$use_external_menu" = "1" ]; then
        external_menu "$1" "$2" "$external_menu_args"
    elif [ "$use_external_menu" = "2" ]; then
        external_menu "$1" "$2"
    fi
}

# Displays the initial mode selection menu via fzf/rofi/dmenu.
# Sets sub_lang, provider, and search based on user choice.
# Exits with 0 if user picks Quit or presses Esc.
main_menu() {
    menu_items="WATCH       English subtitles
WATCH       Spanish subtitles
WATCH       Dubbed Spanish
WATCH       Dubbed English
RESUME      Continue watching
LIBRARY     Search history
EXIT        Close animux"

    if [ "$use_external_menu" = "0" ]; then
        stty_sz="$(stty size 2>/dev/null)"
        if [ -n "$stty_sz" ]; then
            _mm_rows="${stty_sz%% *}"
            _mm_cols="${stty_sz#* }"
        else
            _mm_rows="${LINES:-$(tput lines 2>/dev/null || printf "40")}"
            _mm_cols="${COLUMNS:-$(tput cols 2>/dev/null || printf "120")}"
        fi
        case "$_mm_rows" in "" | *[!0-9]*) _mm_rows=40 ;; esac
        case "$_mm_cols" in "" | *[!0-9]*) _mm_cols=120 ;; esac

        # fzf occupies 95% of the terminal and divides the usable width in
        # half. Center the complete left-hand content block in that space.
        _mm_panel_h=$(( _mm_rows - 4 ))
        [ "$_mm_panel_h" -lt 10 ] && _mm_panel_h=10
        _mm_left_w=$(( _mm_cols / 2 - 2 ))
        [ "$_mm_left_w" -lt 10 ] && _mm_left_w=10
        _mm_header_raw="$(ui_main_header)"
        _mm_header_lines="$(printf '%s\n' "$_mm_header_raw" | wc -l | tr -d '[:space:]')"
        _mm_content_h=$(( _mm_header_lines + 8 ))
        _mm_top_pad=$(( (_mm_panel_h - _mm_content_h) / 2 ))
        [ "$_mm_top_pad" -lt 0 ] && _mm_top_pad=0
        launcher_header="$(ui_center_text_block \
            "$_mm_header_raw" "$_mm_left_w" "$_mm_top_pad")"

        _mm_menu_w=$(( _mm_left_w - 4 ))
        [ "$_mm_menu_w" -lt 1 ] && _mm_menu_w=1
        menu_items="$(ui_center_text_block "$menu_items" "$_mm_menu_w" 0)"
        main_menu_prompt="$(ui_center_text_block 'choose a path' "$_mm_left_w" 0)"

        # Prepare and center the ASCII art in the right-hand panel.
        launcher_preview_file=""
        launcher_preview_image=""
        main_menu_ascii_file="$animux_ascii_art"

        if [ -r "$main_menu_ascii_file" ] && command -v perl >/dev/null 2>&1; then
            _mm_art_h=$(( _mm_panel_h - 2 ))
            [ "$_mm_art_h" -lt 1 ] && _mm_art_h=1
            _mm_preview_w="$_mm_left_w"
            _mm_art_w=$(( _mm_preview_w - 2 ))
            [ "$_mm_art_w" -lt 1 ] && _mm_art_w=1

            _mm_preview="$(mktemp "${TMPDIR:-/tmp}/animux-mainmenu-art.XXXXXX")"
            printf "%s" "$ui_accent" >"$_mm_preview"
            ui_scale_braille_art \
                "$main_menu_ascii_file" "$_mm_art_h" "$_mm_art_w" \
                "$_mm_preview_w" "$_mm_panel_h" >>"$_mm_preview"
            printf "%s" "$ui_reset" >>"$_mm_preview"

            export ANI_CLI_LAUNCHER_PREVIEW_FILE="$_mm_preview"
            export ANI_CLI_LAUNCHER_PREVIEW_IMAGE=""
            launcher_preview_file="$_mm_preview"
        fi
    else
        launcher_header="ANIMUX · stream anime from your terminal"
        main_menu_prompt="  choose a path  "
    fi

    launcher_height="${ANI_CLI_MAIN_MENU_HEIGHT:-95%}"
    choice=$(printf "%s\n" "$menu_items" | launcher "" "$main_menu_prompt")
    unset launcher_height
    unset launcher_header
    unset main_menu_prompt

    # Cleanup preview file and clear any lingering graphics
    [ -n "${launcher_preview_file:-}" ] && rm -f "$launcher_preview_file"
    unset launcher_preview_file
    unset launcher_preview_image
    unset ANI_CLI_LAUNCHER_PREVIEW_FILE
    unset ANI_CLI_LAUNCHER_PREVIEW_IMAGE
    [ -t 2 ] && [ -w /dev/tty ] && printf '\033_Ga=d;\033\\' >/dev/tty 2>/dev/null

    case "$choice" in
        *"Dubbed Spanish"*)
            sub_lang="es"
            mode="dub"
            provider="auto"
            ;;
        *"Dubbed English"*)
            sub_lang="en"
            mode="dub"
            provider="auto"
            ;;
        *"Spanish subtitles"*)
            sub_lang="es"
            mode="sub"
            provider="auto"
            ;;
        *"English subtitles"*)
            sub_lang="en"
            mode="sub"
            provider="auto"
            ;;
        *Continue*)
            search="history"
            ;;
        *LIBRARY*)
            search="search_history"
            ;;
        *)
            exit 0
            ;;
    esac
}

# Checks if the interactive menu should be shown and displays it.
# Only called when initial_menu_eligible=1 (no CLI args provided).
# Translates the menu selection into state variables and returns 0.
select_initial_mode() {
    launcher_available=0
    if [ "$use_external_menu" = "1" ] && command -v rofi >/dev/null 2>&1; then
        launcher_available=1
    elif [ "$use_external_menu" = "2" ] && command -v dmenu >/dev/null 2>&1; then
        launcher_available=1
    elif [ "$use_external_menu" = "0" ] && command -v fzf >/dev/null 2>&1; then
        launcher_available=1
    fi

    if [ "$launcher_available" = "1" ]; then
        main_menu
    fi
    return 0
}

is_cancelled() {
    [ "$1" -eq 130 ]
}

nth() {
    stdin=$(cat -)
    [ -z "$stdin" ] && return 130
    line_count="$(printf "%s\n" "$stdin" | wc -l | tr -d "[:space:]")"
    [ "$line_count" -eq 1 ] && [ "$auto_select_single" = "1" ] && printf "%s" "$stdin" | cut -f2,3 && return 0
    prompt="$1"
    multi_flag=""
    [ $# -ne 1 ] && shift && multi_flag="$1"
    line=$(printf "%s" "$stdin" | cut -f1,3 | tr '\t' ' ' | launcher "$multi_flag" "$prompt" | cut -d " " -f 1)
    line_start=$(printf "%s" "$line" | head -n1)
    line_end=$(printf "%s" "$line" | tail -n1)
    [ -n "$line" ] || return 130
    if [ "$line_start" = "$line_end" ]; then
        printf "%s" "$stdin" | grep -E '^'"${line}"'($|[[:space:]])' | cut -f2,3 || return 130
    else
        printf "%s" "$stdin" | sed -n '/^'"${line_start}"'$/,/^'"${line_end}$"'/p' || return 130
    fi
}

interactive_search_prompt() {
    if [ -n "$query" ]; then
        printf "%s\n" "$query" | sed "s|+| |g"
        return 0
    fi
    query_input=""
    if [ "$use_external_menu" = "0" ]; then
        query_input="$(terminal_query_launcher)"
        if [ -z "$query_input" ]; then
            return 130
        fi
        printf "%s\n" "$query_input"
        return 0
    else
        query_input=$(printf "" | external_menu "" "Search anime [$(language_display)] (Esc: back): " "$external_menu_args")
        if [ -z "$query_input" ]; then
            return 130
        fi
        printf "%s\n" "$query_input"
        return 0
    fi
}

interactive_select_anime() {
    if [ -n "$index" ]; then
        if [ "$index" -eq "$index" ] 2>/dev/null; then
            select_result=$(printf "%s" "$1" | sed -n "${index}p")
            if [ -z "$select_result" ]; then
                die "Invalid index: $index (no result found at this position)"
            fi
            printf "%s\n" "$select_result"
            return 0
        else
            die "Invalid index: $index (must be a number)"
        fi
    fi
    if [ "$use_external_menu" = "0" ]; then
        launcher_header="$(ui_compact_header "search results" "enter select   esc back   $(language_display)")"
    else
        launcher_header="Enter: select · Esc: back · $(language_display)"
    fi
    select_result=$(printf "%s" "$1" | nl -w 2 | sed 's/^[[:space:]]//' | nth "  choose anime  ")
    rc=$?
    unset launcher_header
    if [ "$rc" -eq 130 ] || [ -z "$select_result" ]; then
        return 130
    fi
    printf "%s\n" "$select_result"
    return 0
}

interactive_select_episode() {
    if [ -n "$ep_no" ]; then
        printf "%s\n" "$ep_no"
        return 0
    fi
    if [ "$use_external_menu" = "0" ]; then
        launcher_header="$(ui_episode_header "$title")"
        launcher_height="${ANI_CLI_EPISODE_MENU_HEIGHT:-95%}"
        ui_prepare_episode_preview "$title" || true
    else
        launcher_header="Enter: select · Esc: back · $(clean_display_title "$title")"
    fi
    select_ep=$(printf "%s" "$1" | nth "  choose episode  " "$multi_selection_flag")
    rc=$?
    ui_cleanup_episode_preview
    unset launcher_height
    unset launcher_header
    if [ "$rc" -eq 130 ] || [ -z "$select_ep" ]; then
        return 130
    fi
    printf "%s\n" "$select_ep"
    return 0
}

die() {
    printf "\33[2K\r%s%sfailed%s  %s\n" "$ui_bold" "$ui_error" "$ui_reset" "$*" >&2
    exit 1
}

resolve_provider() {
    case "$provider" in
        auto | "")
            case "$sub_lang" in
                es) printf "python-extractor" ;;
                en) printf "allanime" ;;
                *) return 1 ;;
            esac
            ;;
        allanime | python-extractor)
            printf "%s" "$provider"
            ;;
        jkanime)
            # Backwards-compatible alias for older configs and CLI examples.
            printf "python-extractor"
            ;;
        *)
            return 1
            ;;
    esac
}

provider_label() {
    case "$provider" in
        allanime) printf "AllAnime" ;;
        python-extractor) printf "JKanime → AnimeFLV → AnimeAV1" ;;
        *) printf "%s" "$provider" ;;
    esac
}

language_name() {
    case "$sub_lang" in
        es) printf "Spanish" ;;
        en) printf "English" ;;
        *) printf "%s" "$sub_lang" ;;
    esac
}

language_display() {
    if [ "$mode" = "dub" ]; then
        printf "Dubbed %s" "$(language_name)"
