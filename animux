        *Failed* | *failed* | *No\ * | *Out\ of\ range*) status_color="$ui_warning" ;;
        *Opening* | *Playing*) status_color="$ui_success" ;;
        *) status_color="$ui_accent_alt" ;;
    esac
    printf "\33[2K\r%s::%s  %s\n" "$status_color" "$ui_reset" "$*" >&2
}

